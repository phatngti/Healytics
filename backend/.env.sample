# Postgres configuration - keep in sync with docker-compose
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=mydb

# JWT configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=3600s
JWT_REFRESH_EXPIRES_IN=7d

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass!@#123

# Nest environment
NODE_ENV=development