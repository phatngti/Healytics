        "send_message": {
          "description": "Send a chat message",
          "payload": "WsSendMessagePayload",
          "ack": "WsMessageSentAck"
        },
        "typing": {
          "description": "Notify the other party that the user is typing",
          "payload": "WsTypingPayload"
        },
        "stop_typing": {
          "description": "Notify the other party that the user stopped typing",
          "payload": "WsTypingPayload"
        },
        "mark_read": {
          "description": "Mark all messages in a conversation as read",
          "payload": "WsMarkReadPayload"
        },
        "join_conversation": {
          "description": "Join a conversation room (auto-joined on connect; use for new conversations)",
          "payload": "WsJoinConversationPayload"
        }
      },
      "serverToClient": {
        "new_message": {
          "description": "A new message was sent in a conversation the user has joined",
          "payload": "WsNewMessageEvent"
        },
        "message_sent": {
          "description": "Acknowledgement that the server persisted the user's message",
          "payload": "WsMessageSentAck"
        },
        "messages_read": {
          "description": "The other party read messages in a conversation",
          "payload": "WsMessagesReadEvent"
        },
        "typing": {
          "description": "The other party is typing in a conversation",
          "payload": "WsTypingEvent"
        },
        "stop_typing": {
          "description": "The other party stopped typing",
          "payload": "WsStopTypingEvent"
        },
        "error": {
          "description": "A server error occurred while processing a WS event",
          "payload": "WsErrorEvent"
        }
      }
    },
    "partner-chat": {
