{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Auto-generated from backend WS decorators — DO NOT EDIT BY HAND. Run: yarn generate:ws-contract",
  "namespaces": {
    "user-chat": {
      "description": "User (patient) WebSocket gateway",
      "auth": {
        "type": "jwt",
        "roles": [
          "user"
        ]
