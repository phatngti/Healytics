  "info": {
    "title": "Healytics Test Backdoor API",
    "description": "Endpoints used exclusively by Patrol / integration tests to seed and reset the test database.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "BackdoorStatusResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "database": {
            "type": "string",
            "example": "healytics_test"
          },
          "nodeEnv": {
            "type": "string",
            "example": "test"
          }
        },
        "required": [
          "ok",
          "database",
          "nodeEnv"
        ]
      },
      "ResetDbResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "truncatedTables": {
            "type": "number",
            "example": 12
          }
        },
        "required": [
          "ok",
          "truncatedTables"
        ]
      },
      "SeedUserDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key for this seeded user"
          },
          "email": {
            "type": "string",
            "example": "user@test.healytics.vn"
          },
          "password": {
            "type": "string",
            "example": "Password123!"
          },
          "firstName": {
            "type": "string",
            "example": "Nguyen"
          },
          "lastName": {
            "type": "string",
            "example": "Van A"
          },
          "phone": {
            "type": "string",
            "example": "0901234567"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SeedCategoryDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "name": {
            "type": "string",
            "example": "Spa & Beauty"
          },
          "slug": {
            "type": "string",
            "example": "spa-beauty"
          },
          "description": {
            "type": "string"
          },
          "iconName": {
            "type": "string",
            "example": "spa"
          },
          "colorValue": {
            "type": "string",
            "example": "#FF6B6B"
          },
          "sortOrder": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "name"
        ]
      },
      "SeedPartnerDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "email": {
            "type": "string",
            "example": "partner@test.healytics.vn"
          },
          "password": {
            "type": "string",
            "example": "Password123!"
          },
          "taxCode": {
            "type": "string",
            "example": "TAX-12345"
          },
          "legalName": {
            "type": "string",
            "example": "Healytics Spa LLC"
          },
          "brandName": {
            "type": "string",
            "example": "Healytics Spa"
          },
          "businessTypes": {
            "description": "Business type categories",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "streetAddress": {
            "type": "string",
            "example": "District 1, Ho Chi Minh City"
          },
          "phoneNumber": {
            "type": "string",
            "example": "0901234567"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "APPROVED",
              "REJECTED",
              "REQUIRED_RESUBMIT"
            ],
            "description": "Verification status"
          }
        },
        "required": [
          "brandName"
        ]
      },
      "WorkScheduleEntryDto": {
        "type": "object",
        "properties": {
          "day": {
            "type": "string",
            "example": "Monday",
            "description": "Day of the week",
            "enum": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
              "Sunday"
            ]
          },
          "start": {
            "type": "string",
            "example": "09:00",
            "description": "Work start time in HH:mm format. Empty string if not working."
          },
          "end": {
            "type": "string",
            "example": "17:00",
            "description": "Work end time in HH:mm format. Empty string if not working."
          },
          "isWorking": {
            "type": "boolean",
            "example": true,
            "description": "Whether the employee is working on this day."
          }
        },
        "required": [
          "day",
          "isWorking"
        ]
      },
      "SeedEmployeeDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "partnerKey": {
            "type": "string",
            "description": "Key of a previously seeded partner"
          },
          "partnerBrandName": {
            "type": "string",
            "description": "Brand name to look up the partner"
          },
          "email": {
            "type": "string",
            "example": "emp@test.healytics.vn"
          },
          "employeeCode": {
            "type": "string",
            "example": "EMP-001"
          },
          "firstName": {
            "type": "string",
            "example": "Nguyen"
          },
          "lastName": {
            "type": "string",
            "example": "Van B"
          },
          "displayName": {
            "type": "string",
            "example": "Dr. Nguyen Van B"
          },
          "phone": {
            "type": "string",
            "example": "0912345678"
          },
          "role": {
            "type": "string",
            "enum": [
              "DOCTOR",
              "THERAPIST",
              "RECEPTIONIST",
              "MANAGER"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "INACTIVE",
              "ON_LEAVE"
            ]
          },
          "schedule": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkScheduleEntryDto"
            }
          }
        },
        "required": [
          "displayName"
        ]
      },
      "SeedServiceDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "partnerKey": {
            "type": "string",
            "description": "Key of a previously seeded partner"
          },
          "partnerBrandName": {
            "type": "string",
            "description": "Brand name to look up the partner"
          },
          "employeeKeys": {
            "description": "Keys of previously seeded employees",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "categoryKey": {
            "type": "string",
            "description": "Key of a previously seeded category"
          },
          "categoryName": {
            "type": "string",
            "description": "Category name (auto-created if missing)"
          },
          "name": {
            "type": "string",
            "example": "Deep Tissue Massage"
          },
          "slug": {
            "type": "string",
            "example": "deep-tissue-massage"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "example": 500000
          },
          "durationMinutes": {
            "type": "number",
            "example": 60
          },
          "vendorName": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "SeedCouponDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "code": {
            "type": "string",
            "example": "SUMMER20"
          },
          "discountPercent": {
            "type": "number",
            "example": 20
          },
          "maxDiscountAmount": {
            "type": "number",
            "example": 100000
          },
          "usageLimit": {
            "type": "number",
            "example": 50
          },
          "serviceKey": {
            "type": "string",
            "description": "Key of a previously seeded service"
          },
          "serviceSlug": {
            "type": "string",
            "description": "Slug to look up the service"
          },
          "categoryName": {
            "type": "string",
            "description": "Category name (auto-created if missing)"
          },
          "expiresAt": {
            "type": "string",
            "example": "2026-12-31T23:59:59Z",
            "description": "ISO 8601 expiry"
          }
        },
        "required": [
          "code",
          "discountPercent"
        ]
      },
      "SeedCartItemDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "userKey": {
            "type": "string",
            "description": "Key of a previously seeded user"
          },
          "userEmail": {
            "type": "string",
            "description": "Email to look up the user"
          },
          "serviceKey": {
            "type": "string",
            "description": "Key of a previously seeded service"
          },
          "serviceSlug": {
            "type": "string",
            "description": "Slug to look up the service"
          },
          "employeeKey": {
            "type": "string",
            "description": "Key of a previously seeded employee"
          },
          "employeeEmail": {
            "type": "string",
            "description": "Email to look up the employee"
          },
          "startsAt": {
            "type": "string",
            "example": "2026-06-01T10:00:00Z",
            "description": "ISO 8601 start time"
          }
        },
        "required": [
          "startsAt"
        ]
      },
      "SeedBookingDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "userKey": {
            "type": "string",
            "description": "Key of a previously seeded user"
          },
          "userEmail": {
            "type": "string",
            "description": "Email to look up the user"
          },
          "serviceKey": {
            "type": "string",
            "description": "Key of a previously seeded service"
          },
          "serviceSlug": {
            "type": "string",
            "description": "Slug to look up the service"
          },
          "employeeKey": {
            "type": "string",
            "description": "Key of a previously seeded employee"
          },
          "employeeEmail": {
            "type": "string",
            "description": "Email to look up the employee"
          },
          "startsAt": {
            "type": "string",
            "example": "2026-06-01T10:00:00Z",
            "description": "ISO 8601 start time"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING_PAYMENT",
              "CONFIRMED",
              "IN_PROGRESS",
              "CANCELLED",
              "COMPLETED",
              "NO_SHOW"
            ]
          },
          "endsAt": {
            "type": "string",
            "example": "2026-06-01T11:00:00Z",
            "description": "ISO 8601 end time"
          },
          "paymentUrl": {
            "type": "string",
            "example": "https://pay.stripe.com/xxx"
          },
          "paymentExpiresAt": {
            "type": "string",
            "example": "2026-06-01T10:30:00Z"
          }
        },
        "required": [
          "startsAt"
        ]
      },
      "SeedNotificationDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique lookup key"
          },
          "userKey": {
            "type": "string",
            "description": "Key of a previously seeded user"
          },
          "userEmail": {
            "type": "string",
            "description": "Email to look up the recipient user"
          },
          "senderKey": {
            "type": "string",
            "description": "Key of a previously seeded sender account"
          },
          "senderEmail": {
            "type": "string",
            "description": "Email to look up the sender account"
          },
          "type": {
            "type": "string",
            "enum": [
              "booking_confirmed",
              "booking_cancelled",
              "booking_completed",
              "appointment_reminder",
              "appointment_updated",
              "new_chat_message",
              "payment_success",
              "payment_failed",
              "system_broadcast",
              "system_maintenance",
              "partner_verified",
              "partner_rejected"
            ]
          },
          "title": {
            "type": "string",
            "example": "Booking confirmed"
          },
          "body": {
            "type": "string",
            "example": "Your appointment is confirmed."
          },
          "data": {
            "type": "object"
          },
          "isRead": {
            "type": "boolean",
            "default": false
          },
          "isBroadcast": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "type",
          "title",
          "body"
        ]
      },
      "SeedPayloadDto": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedUserDto"
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedCategoryDto"
            }
          },
          "partners": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedPartnerDto"
            }
          },
          "employees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedEmployeeDto"
            }
          },
          "services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedServiceDto"
            }
          },
          "coupons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedCouponDto"
            }
          },
          "cartItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedCartItemDto"
            }
          },
          "bookings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedBookingDto"
            }
          },
          "notifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeedNotificationDto"
            }
          }
        }
      },
      "BackdoorPrepareDto": {
        "type": "object",
        "properties": {
          "scenario": {
            "type": "string",
            "example": "login-flow",
            "description": "Scenario name"
          },
          "payload": {
            "$ref": "#/components/schemas/SeedPayloadDto"
          }
        }
      },
      "SeedIdsMapDto": {
        "type": "object",
        "properties": {
          "users": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
