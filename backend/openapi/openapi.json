  "info": {
    "title": "The Sync App API",
    "description": "This a the project document",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterProfileDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Jane"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          },
          "phone": {
            "type": "string",
            "example": "+1234567890"
          },
          "bio": {
            "type": "string",
            "example": "Patient is healthy",
            "description": "Short bio or notes"
          },
          "dateOfBirth": {
            "type": "string",
            "example": "1990-01-01",
            "description": "Date of birth in ISO format"
          }
        }
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "newuser@example.com",
            "description": "Email address for registration"
          },
          "password": {
            "type": "string",
            "example": "s3cureP@ssw0rd",
            "description": "Password (min 8 characters)"
          },
          "profile": {
            "description": "Optional profile data to create alongside the account",
            "allOf": [
              {
                "$ref": "#/components/schemas/RegisterProfileDto"
              }
            ]
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "newuser@example.com",
            "description": "The email of the user",
            "format": "email"
          },
          "password": {
            "type": "string",
            "example": "s3cureP@ssw0rd",
            "description": "The password of the user",
            "format": "password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SurveyDto": {
        "type": "object",
        "properties": {
          "survey": {
            "type": "object",
            "description": "Arbitrary survey payload. Example structure below.",
            "example": {
              "demographics": {
                "age": 34,
                "gender": "female",
                "postalCode": "94107"
              },
              "lifestyle": {
                "smoking": false,
                "alcoholWeeklyUnits": 3,
                "exercisePerWeek": 4
              },
              "conditions": [
                {
                  "name": "hypertension",
                  "diagnosedYear": 2018
                },
                {
                  "name": "asthma",
                  "diagnosedYear": 2010
                }
              ],
              "questionnaire": [
                {
                  "questionId": "q1",
                  "answer": "yes"
                },
                {
                  "questionId": "q2",
                  "answer": "no"
                }
              ],
              "submittedAt": "2025-11-22T10:30:15.970Z"
            }
          }
        },
        "required": [
          "survey"
        ]
      }
    }
  }
}