# ══════════════════════════════════════════════════════════════════════════════
# Healytics Performance Test Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your local/CI environment.
# This file is loaded by common/config.py (Python/Locust) and
# scripts/register_perf_accounts.js (Node.js) automatically.

# ── Backend Target ────────────────────────────────────────────────────────────
TARGET_HOST=http://localhost:8080

# ── PostgreSQL (used by register_perf_accounts.js) ────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=healytics

# ── Test Credentials ─────────────────────────────────────────────────────────
# End-user (role: USER)
TEST_USER_EMAIL=user@healytics.vn
TEST_USER_PASSWORD=user@123

# Partner (role: PARTNER)
TEST_PARTNER_EMAIL=partner@healytics.vn
TEST_PARTNER_PASSWORD=partner@123

# Admin (role: ADMIN)
TEST_ADMIN_EMAIL=admin@healytics.vn
TEST_ADMIN_PASSWORD=admin@123

# Employee (role: EMPLOYEE)
TEST_EMPLOYEE_EMAIL=employee.coordinator@healytics.vn
TEST_EMPLOYEE_PASSWORD=employee@123

# ── Timing ────────────────────────────────────────────────────────────────────
MIN_WAIT=1
MAX_WAIT=3

# ── Performance Target Thresholds ─────────────────────────────────────────────
PERF_API_P95_MS=200
PERF_TARGET_USERS=1000
PERF_TARGET_TPS=500
PERF_MAX_ERROR_RATE_PERCENT=0.01
PERF_APP_LOAD_MS=2000
PERF_MAX_CPU_PERCENT=80
PERF_MAX_RAM_PERCENT=80
PERF_MAX_NETWORK_LATENCY_MS=100

# ── Mutation Guards ───────────────────────────────────────────────────────────
# Set to 1/true to enable destructive mutation tests (finance, employee)
PERF_ENABLE_MUTATIONS=0
PERF_ENABLE_EMPLOYEE_MUTATIONS=0

# ── Discovery / Stress Tuning ─────────────────────────────────────────────────
DISCOVERY_PAGE_LIMIT=100
FINANCE_STRESS_PERIODS=sevenDays,thirtyDays,ninetyDays

# ── Perf Account Generation (register_perf_accounts.js) ──────────────────────
PERF_ACCOUNT_COUNT=1200
# PERF_ACCOUNT_EMAIL_PREFIX=perfload-user-
# PERF_ACCOUNT_EMAIL_DOMAIN=perf.healytics.vn
# PERF_ACCOUNT_PASSWORD=Perf@12345
# PERF_ACCOUNT_BCRYPT_ROUNDS=10

# ── Actual Test Results (fill in after running system-level benchmarks) ───────
# PERF_APP_LOAD_RESULT_MS=
# PERF_CPU_RESULT_PERCENT=
# PERF_RAM_RESULT_PERCENT=
# PERF_NETWORK_LATENCY_RESULT_MS=
