# Dedicated Docker Compose environment for backend performance testing.
# Copy to compose.env for local overrides.

COMPOSE_PROJECT_NAME=healytics_perf
PERF_COMPOSE_NETWORK_NAME=healytics_perf_services

# Backend images built from ../../Dockerfile unless overridden.
PERF_BACKEND_IMAGE=healytics-perf-backend:local
PERF_BACKEND_MIGRATION_IMAGE=healytics-perf-backend-migrate:local
PERF_BACKEND_ENV_FILE=./backend.env.example

# Published host ports for the dedicated test stack.
PERF_BACKEND_PORT=8080
PERF_POSTGRES_PORT=55432
PERF_REDIS_PORT=56379
PERF_RABBITMQ_PORT=55672
PERF_RABBITMQ_MANAGEMENT_PORT=15672
PERF_ELASTICSEARCH_PORT=59200

# Strict backend runtime limits used by docker compose.
BACKEND_LIMIT_CPUS=2.0
BACKEND_LIMIT_MEMORY=4G

# Dependency service credentials. Keep matching backend.env.
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=healytics_perf

REDIS_PASSWORD=redispass!@#123

RABBITMQ_DEFAULT_USER=perf
RABBITMQ_DEFAULT_PASS=perf_rmq123

ELASTIC_PASSWORD=elastic@123
ES_JAVA_OPTS="-Xms512m -Xmx512m"
