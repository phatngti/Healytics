# Backend runtime environment for the dedicated performance Compose stack.
# Same key contract as /Volumes/WD850X/Users/workspace/datn/Healytics/backend/.env,
# but values point to Docker Compose service names.

# Postgres configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=healytics_perf
POSTGRES_SSL=false

# JWT configuration
JWT_SECRET=perf_jwt_secret_change_me
JWT_EXPIRES_IN=36000s
JWT_REFRESH_EXPIRES_IN=7d

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass!@#123
REDIS_USERNAME=
REDIS_TLS=false

# Elasticsearch booking search
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic@123
ELASTICSEARCH_INDEX_BOOKING=booking_search_perf

# Performance/auth caching
AUTH_REFRESH_SESSION_STORE=redis
AUTH_REFRESH_DB_FALLBACK=true
AUTH_REFRESH_DUAL_WRITE=false
AUTH_EMAIL_EXISTS_TRUE_TTL_SECONDS=1800
AUTH_EMAIL_EXISTS_FALSE_TTL_SECONDS=60
ACCOUNT_ME_CACHE_TTL_SECONDS=300
PARTNER_VERIFICATION_CACHE_TTL_SECONDS=300
HTTP_ACCESS_LOG_ENABLED=false
HTTP_BODY_LOG_ENABLED=false
HTTP_LOG_SAMPLE_RATE=0.01
PERF_MODE=true
PERF_METRICS_ENABLED=true
PERF_METRICS_LOG_INTERVAL_MS=30000
PERF_EVENT_LOOP_RESOLUTION_MS=20
PERF_METRICS_ROUTE_SAMPLE_LIMIT=2048
STRIPE_WEBHOOK_BODY_LIMIT=2mb
UV_THREADPOOL_SIZE=8

# Nest environment
NODE_ENV=production
PORT=8080

# WebSocket configuration
WS_CORS_ORIGIN=*

# Push notifications
PUSH_NOTIFICATIONS_ENABLED=false
FCM_PROJECT_ID=perf
FCM_CLIENT_EMAIL=perf@example.com
FCM_PRIVATE_KEY=
FCM_PRIVATE_KEY_PATH=
FCM_SERVICE_ACCOUNT_JSON=
APNS_KEY_ID=PERF
APNS_TEAM_ID=PERF
APNS_BUNDLE_ID=com.healytics.perf
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=false

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=perf
R2_ACCESS_KEY_ID=perf
R2_SECRET_ACCESS_KEY=perf
R2_BUCKET_NAME=perf
R2_PUBLIC_URL=http://localhost/perf-r2

# RabbitMQ configuration
RABBITMQ_URL=amqp://perf:perf_rmq123@rabbitmq:5672/%2F
RABBITMQ_QUEUE_CHECKOUT=checkout_queue
RABBITMQ_CA_CERT=
RABBITMQ_CLIENT_CERT=
RABBITMQ_CLIENT_KEY=

# Mapbox
MAPBOX_ACCESS_TOKEN=perf
MAPBOX_PUBLIC_TOKEN=perf

# AI Service
AI_API_TOKEN=perf

# MoMo Payment Gateway
MOMO_PARTNER_CODE=PERF
MOMO_ACCESS_KEY=perf
MOMO_SECRET_KEY=perf
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
MOMO_IPN_URL=
MOMO_REDIRECT_URL=healytics://payment/momo/success

# Stripe
STRIPE_SECRET_KEY=sk_test_perf
STRIPE_WEBHOOK_SECRET=whsec_perf
STRIPE_CURRENCY=vnd

# App configuration
APP_BACKEND_URL=http://backend:8080

# Default admin credentials
DEFAULT_ADMIN_EMAIL=admin@healytics.vn
DEFAULT_ADMIN_PASSWORD=admin@123
