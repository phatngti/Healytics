                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "title": "Id"
                    },
                    "conversationId": {
                        "type": "string",
                        "format": "uuid",
                        "title": "Conversationid"
                    },
                    "role": {
                        "type": "string",
                        "title": "Role"
