                    "recommendations": {
                        "items": {
                            "$ref": "#/components/schemas/ServiceDetail"
                        },
                        "type": "array",
                        "title": "Recommendations"
                    },
                    "total": {
                        "type": "integer",
                        "title": "Total"
                    },
                    "timestamp": {
                        "type": "string",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": [
                    "conversation_id",
                    "recommendations",
                    "total",
                    "timestamp"
                ],
                "title": "ChatbotRecommendationResponse"
            },
            "ChatbotRecommenderRequest": {
                "properties": {
                    "conversation_id": {
                        "type": "string",
                        "title": "Conversation Id"
                    },
                    "query": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Query"
                    },
                    "top_k": {
                        "type": "integer",
                        "maximum": 20.0,
                        "minimum": 1.0,
                        "title": "Top K",
                        "default": 3
                    },
                    "filtered_ids": {
                        "anyOf": [
                            {
                                "items": {
                                    "type": "string"
                                },
                                "type": "array"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Filtered Ids"
                    }
                },
                "type": "object",
                "required": [
                    "conversation_id",
                    "query"
                ],
                "title": "ChatbotRecommenderRequest"
            },
