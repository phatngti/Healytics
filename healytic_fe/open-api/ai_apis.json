                "properties": {
                    "conversation_id": {
                        "anyOf": [
                            {
                                "type": "string",
                                "format": "uuid"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Conversation Id"
                    },
                    "user_id": {
                        "type": "string",
                        "title": "User Id"
                    },
                    "message": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Message"
                    },
                    "top_k": {
                        "type": "integer",
                        "maximum": 20.0,
                        "minimum": 1.0,
                        "title": "Top K",
                        "default": 3
                    }
                },
                "type": "object",
