@startchen
left to right direction

' =============================
' ENTITY: ACCOUNT & SUBTYPES
' =============================
entity Account {
  account_id : INTEGER <<key>>
  email : STRING
  password : STRING
  creation_date : DATE
  last_login : DATETIME
  is_active : BOOLEAN
}

entity User {
  name {
    first_name : STRING
    last_name : STRING
  }
  phone : STRING
  address : STRING
  date_of_birth : DATE
  profile_completed : BOOLEAN
  loyalty_points : INTEGER <<derived>>
}

entity Partner {
  business_name : STRING
  legal_rep : STRING
  status : STRING
  registration_date : DATE
  business_address : STRING
  tax_id : STRING
  contact_email : STRING
  contact_phone : STRING
}

entity Employee {
  employee_id : INTEGER <<key>>
  role : STRING
  name : STRING
  email : STRING
  hire_date : DATE
}

entity Admin {
  admin_id : INTEGER <<key>>
  name : STRING
  email : STRING
  role : STRING
  last_access : DATETIME
}

Account =>= d { User, Partner, Employee, Admin }

' =============================
' USER PREFERENCE
' =============================
entity UserPreference <<weak>> {
  preference : STRING <<key>>
  value : STRING
}

relationship HasPreference <<identifying>> {
  set_date : DATE
}

HasPreference -1- User
HasPreference =N= UserPreference

' =============================
' PARTNER DOCUMENTS
' =============================
entity PartnerDocument <<weak>> {
  document_name : STRING <<key>>
  url : STRING
  upload_date : DATE
  document_type : STRING
}

relationship HasDocument <<identifying>> {
  verified : BOOLEAN
  verification_date : DATE
}

HasDocument -1- Partner
HasDocument =N= PartnerDocument

' =============================
' SERVICES
' =============================
entity Service {
  service_id : INTEGER <<key>>
  name : STRING
  description : STRING
  price : REAL
  duration : INTEGER
  is_active : BOOLEAN
}

relationship Provides {
  since : DATE
}

Provides -1- Partner
Provides -N- Service

entity ServiceImage <<weak>> {
  image_url : STRING <<key>>
  caption : STRING
  upload_date : DATE
}

relationship HasImage <<identifying>> {}

HasImage -1- Service
HasImage =N= ServiceImage

' =============================
' APPOINTMENT & BOOKING
' =============================
entity Appointment {
  appointment_id : INTEGER <<key>>
  datetime : DATETIME
  status : STRING
  note : STRING <<multi>>
  cancellation_reason : STRING
}

relationship Books {
  date_booked : DATE
}

Books -1- User
Books -N- Appointment

relationship Schedules {
  confirmed : BOOLEAN
  confirmation_date : DATE
}

Schedules -N- Appointment
Schedules -1- Service

relationship AssignedToAppointment {
  assigned_date : DATE
}

AssignedToAppointment -N- Appointment
AssignedToAppointment -1- Employee

' =============================
' PAYMENT
' =============================
entity Payment {
  payment_id : INTEGER <<key>>
  amount : REAL
  method : STRING
  transaction_id : STRING
  payment_date : DATE
  status : STRING
}

relationship PaysFor {}

PaysFor =1= Payment
PaysFor -1- Appointment

' =============================
' REVIEWS
' =============================
entity Review {
  review_id : INTEGER <<key>>
  rating : INTEGER
  comment : STRING
  review_date : DATE
  is_approved : BOOLEAN
}

relationship Reviews {
  date : DATE
}

Reviews =1= Review
Reviews -1- Appointment

' =============================
' TICKETS
' =============================
entity Ticket {
  ticket_id : INTEGER <<key>>
  description : STRING
  status : STRING
  creation_date : DATE
  priority : STRING
}

relationship CreatesTicket {
  created_at : DATETIME
}

CreatesTicket -1- Account
CreatesTicket -N- Ticket

relationship HandlesTicket {
  resolution : STRING
  date_resolved : DATE
}

HandlesTicket -N- Ticket
HandlesTicket -1- Admin

' =============================
' PROMOTION
' =============================
entity Promotion {
  promotion_id : INTEGER <<key>>
  name : STRING
  description : STRING
  start_date : DATE
  end_date : DATE
  conditions : STRING
  discount_value : REAL
}

relationship CreatesPromotion {
  created_date : DATE
}

CreatesPromotion -1- Partner
CreatesPromotion -N- Promotion

' =============================
' CAMPAIGN
' =============================
entity Campaign {
  campaign_id : INTEGER <<key>>
  name : STRING
  description : STRING
  start_date : DATE
  end_date : DATE
  budget : REAL
}

relationship CreatesCampaign {
  created_date : DATE
}

CreatesCampaign -1- Admin
CreatesCampaign -N- Campaign

' =============================
' VOUCHER
' =============================
entity Voucher {
  voucher_id : INTEGER <<key>>
  code : STRING
  value : REAL
  conditions : STRING
  expiry_date : DATE
  is_used : BOOLEAN
}

relationship HasVoucher {
  issued_date : DATE
}

HasVoucher -1- Campaign
HasVoucher -N- Voucher

relationship Redeems {
  date_used : DATE
}

Redeems -N- User
Redeems -N- Voucher

' =============================
' PAYOUTS
' =============================
entity Payout {
  payout_id : INTEGER <<key>>
  amount : REAL
  date : DATE
  period : STRING
  status : STRING
}

relationship Issues {
  issued_date : DATE
}

Issues -1- Admin
Issues -N- Payout

relationship Receives {}

Receives -N- Payout
Receives -1- Partner

' =============================
' EMPLOYMENT RELATIONS
' =============================
relationship Employs {
  since : DATE
}

Employs -1- Partner
Employs -N- Employee

relationship AssignedService {
  since : DATE
}

AssignedService -N- Employee
AssignedService -N- Service

relationship ApprovesPartner {
  date : DATE
  reason : STRING
}

ApprovesPartner -1- Admin
ApprovesPartner -N- Partner

' =============================
' CONVERSATIONS & MESSAGES
' =============================
entity Conversation {
  conversation_id : INTEGER <<key>>
  start_time : DATETIME
  end_time : DATETIME
  status : STRING
}

relationship HasConversation {
  initiated_by : STRING
}

HasConversation -1- User
HasConversation -N- Conversation

entity Message <<weak>> {
  message_id : INTEGER <<key>>
  content : STRING
  sender : STRING
  timestamp : DATETIME
  is_read : BOOLEAN
}

relationship Contains <<identifying>> {}

Contains -1- Conversation
Contains =N= Message

@endchen
