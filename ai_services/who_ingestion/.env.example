# WHO ingestion pipeline — copy to who_ingestion/.env

# -------------------------------------------------------
# Crawl
# -------------------------------------------------------
WHO_DOCS_PER_DOMAIN=50
WHO_CRAWL_DELAY_SECONDS=1.0
WHO_CRAWL_TIMEOUT_SECONDS=45
WHO_CRAWL_RETRIES=3
WHO_CRAWL_MAX_PAGES_PER_QUERY=15
WHO_STAGING_DIR=./data/staging/who

# -------------------------------------------------------
# AWS S3 (tuỳ chọn — để trống nếu chỉ cần OpenSearch)
# -------------------------------------------------------
S3_BUCKET=
S3_PREFIX=who-publications/
AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=   # optional for MinIO / LocalStack

# Xóa PDF tạm trên máy sau khi index OpenSearch (mặc định true)
WHO_DELETE_LOCAL_AFTER_INGEST=true

# -------------------------------------------------------
# Elasticsearch
# -------------------------------------------------------
# API endpoint — KHÔNG dùng URL có /_dashboards (đó là giao diện web)
ELASTICSEARCH_URL=https://search-your-domain.ap-southeast-1.es.amazonaws.com
ELASTICSEARCH_INDEX=healytics_who_chunks
ELASTICSEARCH_API_KEY=
# OpenSearch managed domain (FGAC master user):
# ELASTICSEARCH_USERNAME=healytics_admin
# ELASTICSEARCH_PASSWORD=
# OpenSearch .aos. / Serverless — dùng IAM thay username/password:
# ELASTICSEARCH_USE_AWS_IAM=true
ELASTICSEARCH_VERIFY_CERTS=true
ELASTICSEARCH_RECREATE_INDEX=false

# -------------------------------------------------------
# Chunking + embeddings (shared with rag_langchain)
# -------------------------------------------------------
WHO_CHUNK_TOKEN_SIZE=256
WHO_CHUNK_TOKEN_OVERLAP=32
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
RAG_EMBEDDING_DIMS=768

# -------------------------------------------------------
# Optional translation (WHO docs are English; field content_en = raw text)
# -------------------------------------------------------
MISTRAL_API_KEY=
