# ner-service environment variables
# Copy this file to .env and fill in real values.

# -------------------------------------------------------
# Backend API (for loading categories + locations)
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://admin:admin%40123@localhost:5432/mydb

# -------------------------------------------------------
# Cache config (in-memory)
# -------------------------------------------------------
LOCATION_CACHE_TTL=86400
CATEGORY_CACHE_TTL=300
QUERY_CACHE_MAXSIZE=512
LOCATION_MATCHER_USE_AHO=true
SEMANTIC_OFFLOAD_TO_THREAD=true
SEMANTIC_QUERY_CACHE_MAXSIZE=1000
SEMANTIC_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
SEMANTIC_USE_RETRIEVAL_PREFIX=false

# -------------------------------------------------------
# Service config
# -------------------------------------------------------
PORT=8002

# -------------------------------------------------------
# LLM NER (Gemini)
# -------------------------------------------------------
# Turn on to use Gemini as primary NER extractor.
LLM_NER_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=1500
GEMINI_MAX_RETRIES=1
GEMINI_RETRY_BACKOFF_MS=400
GEMINI_COOLDOWN_SECONDS=30

# -------------------------------------------------------
# Semantic thresholds
# -------------------------------------------------------
SEMANTIC_BT_HIGH_THRESHOLD=0.60
SEMANTIC_BT_MEDIUM_THRESHOLD=0.50
SEMANTIC_CATEGORY_HIGH_THRESHOLD=0.60
SEMANTIC_CATEGORY_MEDIUM_THRESHOLD=0.50
SEMANTIC_TAG_HIGH_THRESHOLD=0.80
SEMANTIC_TAG_MEDIUM_THRESHOLD=0.72
