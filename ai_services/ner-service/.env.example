# ner-service environment variables
# Copy this file to .env and fill in real values.

# -------------------------------------------------------
# Backend API (for loading categories + locations)
# -------------------------------------------------------
BACKEND_API_URL=http://localhost:3000

# -------------------------------------------------------
# Cache config (in-memory)
# -------------------------------------------------------
LOCATION_CACHE_TTL=86400
CATEGORY_CACHE_TTL=300
QUERY_CACHE_MAXSIZE=512

# -------------------------------------------------------
# Service config
# -------------------------------------------------------
PORT=8002

# -------------------------------------------------------
# LLM NER (Gemini)
# -------------------------------------------------------
# Turn on to use Gemini as primary NER extractor.
LLM_NER_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=1500
GEMINI_MAX_RETRIES=1
GEMINI_RETRY_BACKOFF_MS=400
GEMINI_COOLDOWN_SECONDS=30
