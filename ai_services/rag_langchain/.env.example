# rag_langchain (chatbot) environment variables
# Copy this file to .env and fill in real values.

# -------------------------------------------------------
# LLM backend: mistral | llama | hf | huggingface
# -------------------------------------------------------
LLM_BACKEND=mistral
MISTRAL_MODEL=mistral-large-latest
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MAX_TOKENS=512
MISTRAL_TEMPERATURE=0.2
MISTRAL_TIMEOUT=320
# MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

# -------------------------------------------------------
# Embedding device: auto | cuda | cpu
# -------------------------------------------------------
EMBEDDING_DEVICE=auto

# -------------------------------------------------------
# RAG mode: standard | advanced
# standard  = Chroma similarity (default, unchanged)
# advanced  = multi-query + hybrid (dense+BM25) + fusion (RRF) + reranker
# -------------------------------------------------------
RAG_MODE=standard
RAG_TOP_K=10
RAG_RERANK_TOP_N=5
RAG_HYBRID_DENSE_WEIGHT=0.5
RAG_HYBRID_SPARSE_WEIGHT=0.5
RAG_MULTI_QUERY_ENABLED=true
RAG_MULTI_QUERY_COUNT=4
RAG_MULTI_QUERY_MODEL=mistral-small-latest
RAG_MULTI_QUERY_INCLUDE_ORIGINAL=true
RAG_QUERY_TRANSLATION_ENABLED=true
RAG_TRANSLATION_MODEL=mistral-small-latest
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_DATA_DIR=./data_source/generative_ai
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=0

# -------------------------------------------------------
# Elasticsearch (required for advanced mode with WHO corpus)
# -------------------------------------------------------
# ELASTICSEARCH_URL=https://your-cluster.es.amazonaws.com:443
# ELASTICSEARCH_INDEX=healytics_who_chunks
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_VERIFY_CERTS=true
