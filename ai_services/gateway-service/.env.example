# gateway-service environment variables
# Copy this file to .env and fill in real values.

# -------------------------------------------------------
# PostgreSQL connection (async DSN for asyncpg driver)
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healytics

# -------------------------------------------------------
# Downstream microservice base URLs
# (these defaults match the docker-compose service names)
# -------------------------------------------------------
CHATBOT_SERVICE_URL=http://chatbot-service:8001
NER_SERVICE_URL=http://ner-service:8002
RECOMMENDER_SERVICE_URL=http://recommender-service:8003

# -------------------------------------------------------
# HTTP client timeouts (seconds)
# -------------------------------------------------------
HTTP_CONNECT_TIMEOUT=5.0
HTTP_READ_TIMEOUT=60.0
HTTP_WRITE_TIMEOUT=10.0
HTTP_POOL_TIMEOUT=5.0
