# gateway-service environment variables
# Copy this file to .env and fill in real values.

# -------------------------------------------------------
# PostgreSQL connection (async DSN for asyncpg driver)
# -------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://admin:GH21112004%40lngh@localhost:5433/healytics

DATABASE_URL=postgresql+asyncpg://healytics:abcd%401234@healytics.postgres.database.azure.com:5432/postgres?ssl=require

# -------------------------------------------------------
# Downstream microservice base URLs
# (these defaults match the docker-compose service names)
# -------------------------------------------------------
CHATBOT_SERVICE_URL=http://healytics_chatbot:5000
RECOMMENDER_SERVICE_URL=http://healytics_recommender:8000

# -------------------------------------------------------
# HTTP client timeouts (seconds)
# -------------------------------------------------------
HTTP_CONNECT_TIMEOUT=5.0
HTTP_READ_TIMEOUT=500.0
HTTP_WRITE_TIMEOUT=10.0
HTTP_POOL_TIMEOUT=5.0
