# =============================================================================
# Backend Runtime Environment
# =============================================================================
# Copy to backend.env on the VPS and fill production secrets.
# Infrastructure values such as POSTGRES_HOST, REDIS_HOST, and RABBITMQ_URL are
# supplied by docker-compose.yml so containers use internal service DNS.

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=3600s
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket
WS_CORS_ORIGIN=*

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Mapbox
MAPBOX_ACCESS_TOKEN=
MAPBOX_PUBLIC_TOKEN=

# AI Service
AI_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=vnd

# MoMo Payment Gateway
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
MOMO_IPN_URL=

# App configuration
APP_BACKEND_URL=

# Default admin credentials for seed scripts, if used manually.
DEFAULT_ADMIN_EMAIL=admin@healytics.vn
DEFAULT_ADMIN_PASSWORD=change-me
