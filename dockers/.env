# =============================================================================
# Docker Compose Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=mydb
POSTGRES_EXTRA_DATABASES=healytics
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=redispass!@#123

# --- Kong Gateway ---
GW_IMAGE=kong/kong-gateway:3.12.0.2
GW_HOST=localhost
KONG_LICENSE_DATA=
KONG_ADMIN_PASSWORD=handyshake

# --- Cloudflare Tunnel ---
# Auto-populated by cloudflare-tunnel-setup.sh, or set manually from:
# https://dash.teams.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

