# =============================================================================
# Docker Compose Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=mydb
# Comma-separated list of extra databases to create on first startup
POSTGRES_EXTRA_DATABASES=kong_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_USERNAME=healytics
REDIS_PASSWORD=redispass!@#123

# --- Backend (prod profile — image+tag are written by deploy-backend.sh → deploy.env) ---
# These defaults are only used if you run deploy-backend.sh without overrides.
BACKEND_IMAGE=nonameaaaa/healytics_backend
BACKEND_TAG=replace-with-immutable-tag
BACKEND_MIGRATION_IMAGE=nonameaaaa/healytics_backend-migrate
BACKEND_RUN_MIGRATIONS=true
RABBITMQ_QUEUE_CHECKOUT=checkout_queue

# --- Admin Panel (panel-prod profile — image+tag are written by deploy-panel.sh → deploy-panel.env) ---
PANEL_IMAGE=nonameaaaa/healytics_panel
PANEL_TAG=replace-with-immutable-tag
PANEL_PORT=3000

# --- Kong Gateway ---
GW_IMAGE=kong/kong-gateway:3.12.0.2
GW_HOST=localhost
KONG_LICENSE_DATA=
KONG_ADMIN_PASSWORD=handyshake
# Kong Manager GUI — set these to your public URLs on the VPS
# so the browser-side UI can call the Admin API without CORS errors.
# KONG_ADMIN_GUI_URL=https://kong.healytics.me
# KONG_ADMIN_GUI_API_URL=https://kong-api.healytics.me

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin@rmq123
RABBITMQ_BACKEND_USER=backend
RABBITMQ_BACKEND_PASS=backend@rmq123
RABBITMQ_BACKEND_PASS_URLENCODED=backend%40rmq123
RABBITMQ_BACKEND_VHOST=healytics

# --- Jenkins Controller (ci profile — VPS only) ---
JENKINS_URL=https://ci.example.com
JENKINS_PORT=8081
JENKINS_ADMIN_PASSWORD=replace-with-strong-password
# Shared secret for GitHub → Jenkins webhook auth (NOT a GitHub credential)
# Generate with: openssl rand -hex 32
WEBHOOK_TOKEN=replace-with-random-string
COMPOSE_NETWORK_NAME=healytics_services

# --- Jenkins Local Inbound Agent (ci-agent profile — local machine only) ---
# These vars are for the developer's local machine, NOT the VPS.
# Keep in a local-only .env or export them in your shell.
# JENKINS_AGENT_URL=https://ci.example.com
# JENKINS_AGENT_SECRET=<copy from Jenkins UI → Manage Nodes>
# HEALYTICS_VPS_HOST=<your-vps-ip-or-hostname>
# HEALYTICS_VPS_SSH_USER=deploy

# --- Cloudflare API (used by cloudflare-configurator service) ---
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Cloudflare Tunnel Write, DNS Write
CLOUDFLARE_API_TOKEN=
# Found at: https://dash.cloudflare.com/ → any domain → Overview (right sidebar, "Account ID")
CLOUDFLARE_ACCOUNT_ID=
# Found at: https://dash.cloudflare.com/ → your domain → Overview (right sidebar, "Zone ID")
CLOUDFLARE_ZONE_ID=
# Path can be overridden via CLOUDFLARE_TUNNELS_FILE (inside the container).
CLOUDFLARE_TUNNELS_FILE=/app/cloudflare-tunnels.json
