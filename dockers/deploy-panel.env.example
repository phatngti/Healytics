# deploy-panel.env — Written automatically by deploy-panel.sh on each deployment.
# Committed example only. The real file is in .gitignore.
# On first deploy, create this file on the VPS with an empty PANEL_TAG
# so the script knows there's nothing to rollback to.
PANEL_IMAGE=nonameaaaa/healytics_panel
PANEL_TAG=
PANEL_DEPLOYED_AT=
