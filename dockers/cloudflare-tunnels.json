{
  "tunnels": [
    {
      "name": "healytics-tunnel",
      "token": "",
      "routes": [
        {
          "hostname": "healytics.me",
          "origin": "http://kong-cp:8000",
          "originRequest": {
            "noTLSVerify": true,
            "connectTimeout": 30,
            "keepAliveTimeout": 3600,
            "keepAliveConnections": 100
          }
        },
        {
          "hostname": "database.healytics.me",
          "origin": "tcp://host.docker.internal:5432",
          "originRequest": {
            "noTLSVerify": true
          }
        }
      ]
    }
  ]
}