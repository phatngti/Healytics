{
  "tunnels": [
    {
      "name": "healytics-tunnel",
      "token": "",
      "routes": [
        {
          "hostname": "healytics.me",
          "origin": "http://kong-cp:8000",
          "originRequest": {
            "noTLSVerify": true,
            "connectTimeout": 30,
            "keepAliveTimeout": 3600,
            "keepAliveConnections": 100
          }
        },
        {
          "hostname": "admin.healytics.me",
          "origin": "http://healytics-panel:80",
          "originRequest": {
            "noTLSVerify": true
          }
        },
        {
          "hostname": "jenkins-webhook.healytics.me",
          "origin": "http://jenkins-controller:8080",
          "originRequest": {
            "noTLSVerify": true,
            "connectTimeout": 10
          }
        }
      ]
    }
  ]
}